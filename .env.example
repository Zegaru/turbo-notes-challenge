# Database (backend uses DATABASE_URL; postgres service uses POSTGRES_*)
DATABASE_URL=postgres://notes:notes@db:5432/notes

# Django
DJANGO_SECRET_KEY=change-me-in-production
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ORIGINS=http://localhost:3000

# Production (Coolify / docker-compose.prod.yml)
# PORT=8000
# MEDIA_ROOT=/data/media
# STATIC_ROOT=/app/staticfiles
# ALLOWED_HOSTS=your-domain.com,api.your-domain.com
# CORS_ORIGINS=https://your-domain.com,https://app.your-domain.com

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# AI category suggestion (optional, default: mock)
# AI_PROVIDER=mock
# AI_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5-mini
# AI_REQUEST_TIMEOUT=10
